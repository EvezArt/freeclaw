# === EVEZ Security .gitignore ===
# Auto-generated by Viktor — prevents credential/secret leaks

# Environment files
.env
.env.local
.env.production
.env.development
.env.staging
.env.*.local
*.env

# Password manager exports
*.kdbx
*.kdb
bitwarden_export*
keepass_export*
*credentials*.csv
*credentials*.json
*credentials*.html
*passwords*.csv
*passwords*.json

# Private keys & certificates
*.pem
*.key
*.p12
*.pfx
*.crt
id_rsa*
id_ed25519*
*.ppk

# API key files
secrets.yml
secrets.yaml
secrets.json
.secrets
*_secret*
*_token*

# Cloud provider credentials
.aws/
.gcp/
service-account*.json
google-credentials*.json

# Node/Python artifacts
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# Build artifacts
dist/
build/
*.tgz
